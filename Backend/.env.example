# App
APP_NAME=VisionCaption AI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated, parsed as JSON list in production platforms)
CORS_ORIGINS=["http://localhost:3000","https://visioncaption.ai"]

# Security
SECRET_KEY=replace-with-a-long-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=sqlite+aiosqlite:///./visioncaption.db

# Caption Model (BLIP)
MODEL_NAME=Salesforce/blip-image-captioning-base
MODEL_CACHE_DIR=./model_cache
MODEL_DEVICE=cpu
MAX_CAPTION_LENGTH=50
MIN_CAPTION_LENGTH=5
NUM_BEAMS=4

# OCR Model (TrOCR)
OCR_MODEL_NAME=microsoft/trocr-base-printed
OCR_MAX_LENGTH=128
ENABLE_OCR=true

# Object Detection Model (DETR)
DETECTION_MODEL_NAME=facebook/detr-resnet-50
DETECTION_CONFIDENCE_THRESHOLD=0.7
MAX_DETECTED_OBJECTS=20
ENABLE_OBJECT_DETECTION=true

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Rate limiting
RATE_LIMIT_FREE_PER_MONTH=50
RATE_LIMIT_PRO_PER_MONTH=2000
RATE_LIMIT_PER_MINUTE=20/minute

# Logging
LOG_LEVEL=INFO